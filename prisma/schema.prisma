generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  naverBlogId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
