generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model SmsVerification {
  id        String   @id @default(cuid())
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  password              String
  name                  String?
  phone                 String?     @unique
  naverBlogId           String?
  naverSession          String?
  sessionUploadedAt     DateTime?
  uploadToken           String?
  uploadTokenExpiresAt  DateTime?
  plan                  String    @default("free")
  billingKey            String?
  billingCustomerKey    String?
  planExpiresAt         DateTime?
  postCount             Int       @default(0)
  postCountResetAt      DateTime  @default(now())
  betaCount             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  posts                 BlogPost[]
  feedbacks             Feedback[]
  waitlist              Waitlist?
}

model BlogPost {
  id           String    @id @default(cuid())
  userId       String
  title        String
  content      String
  businessName String
  keywords     String    @default("[]")
  filePath     String?
  publishedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id             String   @id @default(cuid())
  userId         String
  rating         Int
  publishSuccess Boolean
  comment        String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String?  @unique
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  type      String
  content   String
  createdAt DateTime @default(now())
}

model BetaConfig {
  id       Int @id
  maxUsers Int @default(30)
}
